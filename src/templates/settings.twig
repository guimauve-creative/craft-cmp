{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Settings"|t('craft-cmp') %}
{% set fullPageForm = true %}

{% set crumbs = [
    { label: plugin.getPluginName(), url: url('craft-cmp') },
] %}

{% set signalPlaceholder = signalOptions|keys|join(', ') %}

{# Category options for the scripts table's category column #}
{% set categoryOptions = [] %}
{% for cat in settings.getCategories() %}
    {% set categoryOptions = categoryOptions|merge([{ label: cat.label ?: cat.handle, value: cat.handle }]) %}
{% endfor %}

{% block content %}
    <input type="hidden" name="action" value="plugins/save-plugin-settings">
    <input type="hidden" name="pluginHandle" value="craft-cmp">
    {{ redirectInput('craft-cmp/settings') }}

    {{ forms.textField({
        first: true,
        label: "Plugin name"|t('craft-cmp'),
        instructions: "How the plugin is named in the Control Panel."|t('craft-cmp'),
        id: 'pluginName',
        name: 'settings[pluginName]',
        value: settings.pluginName,
        required: true,
    }) }}

    <hr>
    <h2>{{ "Cookie categories"|t('craft-cmp') }}</h2>

    {{ forms.editableTableField({
        label: "Categories"|t('craft-cmp'),
        instructions: "Each category maps to one or more Google Consent Mode v2 signals. `gtagSignals` is a comma-separated list of: #{signalPlaceholder}."|t('craft-cmp'),
        id: 'categories',
        name: 'settings[categories]',
        cols: {
            handle: { heading: "Handle"|t('craft-cmp'), type: 'singleline', width: '15%' },
            label: { heading: "Label"|t('craft-cmp'), type: 'singleline', width: '20%' },
            description: { heading: "Description"|t('craft-cmp'), type: 'multiline' },
            required: { heading: "Required"|t('craft-cmp'), type: 'lightswitch', width: '10%' },
            gtagSignals: { heading: "Consent Mode signals"|t('craft-cmp'), type: 'singleline', width: '25%', placeholder: signalPlaceholder },
        },
        rows: settings.getCategoriesForTable(),
        addRowLabel: "Add a category"|t('craft-cmp'),
        allowAdd: true,
        allowDelete: true,
        allowReorder: true,
    }) }}

    <hr>
    <h2>{{ "Banner copy"|t('craft-cmp') }}</h2>

    {{ forms.textField({ label: "Banner title"|t('craft-cmp'), id: 'bannerTitle', name: 'settings[bannerTitle]', value: settings.bannerTitle }) }}
    {{ forms.textareaField({ label: "Banner body"|t('craft-cmp'), instructions: "May contain HTML."|t('craft-cmp'), id: 'bannerBody', name: 'settings[bannerBody]', value: settings.bannerBody }) }}
    {{ forms.textField({ label: "“Accept all” label"|t('craft-cmp'), id: 'acceptAllLabel', name: 'settings[acceptAllLabel]', value: settings.acceptAllLabel }) }}
    {{ forms.textField({ label: "“Reject all” label"|t('craft-cmp'), id: 'rejectAllLabel', name: 'settings[rejectAllLabel]', value: settings.rejectAllLabel }) }}
    {{ forms.textField({ label: "“Save preferences” label"|t('craft-cmp'), id: 'savePrefsLabel', name: 'settings[savePrefsLabel]', value: settings.savePrefsLabel }) }}
    {{ forms.textField({ label: "“Manage preferences” label"|t('craft-cmp'), id: 'managePrefsLabel', name: 'settings[managePrefsLabel]', value: settings.managePrefsLabel }) }}

    <hr>
    <h2>{{ "Banner links"|t('craft-cmp') }}</h2>
    <p class="light">{{ "Small links shown at the bottom of the banner (e.g. Privacy policy, Cookie policy)."|t('craft-cmp') }}</p>

    {{ forms.editableTableField({
        label: "Links"|t('craft-cmp'),
        id: 'links',
        name: 'settings[links]',
        cols: {
            label: { heading: "Label"|t('craft-cmp'), type: 'singleline', width: '35%' },
            url: { heading: "URL"|t('craft-cmp'), type: 'singleline', width: '50%', placeholder: 'https://…' },
            newTab: { heading: "New tab"|t('craft-cmp'), type: 'lightswitch', width: '15%' },
        },
        rows: settings.links,
        addRowLabel: "Add a link"|t('craft-cmp'),
        allowAdd: true,
        allowDelete: true,
        allowReorder: true,
        static: false,
    }) }}

    <hr>
    <h2>{{ "Versions"|t('craft-cmp') }}</h2>

    {{ forms.textField({
        label: "Policy version"|t('craft-cmp'),
        instructions: "Bump this to force every visitor to re-consent."|t('craft-cmp'),
        id: 'policyVersion', name: 'settings[policyVersion]', value: settings.policyVersion, required: true, size: 10,
    }) }}
    {{ forms.textField({
        label: "Consent version"|t('craft-cmp'),
        instructions: "Version of the banner/category configuration."|t('craft-cmp'),
        id: 'consentVersion', name: 'settings[consentVersion]', value: settings.consentVersion, required: true, size: 10,
    }) }}

    <hr>
    <h2>{{ "Google Consent Mode v2"|t('craft-cmp') }}</h2>

    {{ forms.lightswitchField({
        label: "Enable Google Consent Mode"|t('craft-cmp'),
        instructions: "When on, the per-category “Consent Mode signals” are sent to Google’s tag (gtag) and the measurement ID below can load GA4. Turn off if you don’t use Google and rely only on the tags/scripts below."|t('craft-cmp'),
        id: 'consentModeEnabled', name: 'settings[consentModeEnabled]', on: settings.consentModeEnabled,
    }) }}
    {{ forms.autosuggestField({
        label: "GA4 measurement ID"|t('craft-cmp'),
        instructions: "Optional. The frontend can read this to self-configure gtag (e.g. G-XXXXXXX). Supports environment variables."|t('craft-cmp'),
        id: 'gaMeasurementId', name: 'settings[gaMeasurementId]', value: settings.gaMeasurementId, suggestEnvVars: true,
    }) }}

    <hr>
    <h2>{{ "Tags & scripts"|t('craft-cmp') }}</h2>
    <p class="light">{{ "Provider-agnostic tags (Meta Pixel, Matomo, Hotjar, LinkedIn, …) that load only when their category is granted. Use an external URL, inline code, or both. These run third-party code on your front-end — only add sources you trust."|t('craft-cmp') }}</p>

    {{ forms.editableTableField({
        label: "Scripts"|t('craft-cmp'),
        id: 'scripts',
        name: 'settings[scripts]',
        cols: {
            name: { heading: "Name"|t('craft-cmp'), type: 'singleline', width: '20%' },
            category: { heading: "Category"|t('craft-cmp'), type: 'select', options: categoryOptions, width: '20%' },
            src: { heading: "External URL"|t('craft-cmp'), type: 'singleline', width: '30%', placeholder: 'https://…' },
            code: { heading: "Inline code"|t('craft-cmp'), type: 'multiline' },
        },
        rows: settings.getScriptsForTable(),
        addRowLabel: "Add a tag"|t('craft-cmp'),
        allowAdd: true,
        allowDelete: true,
        allowReorder: true,
    }) }}

    <hr>
    <h2>{{ "Cookie & storage"|t('craft-cmp') }}</h2>

    {{ forms.textField({ label: "Cookie name"|t('craft-cmp'), id: 'cookieName', name: 'settings[cookieName]', value: settings.cookieName, required: true, size: 20 }) }}
    {{ forms.textField({ label: "Cookie lifetime (days)"|t('craft-cmp'), id: 'cookieLifetimeDays', name: 'settings[cookieLifetimeDays]', value: settings.cookieLifetimeDays, type: 'number', size: 6 }) }}
    {{ forms.textField({
        label: "Record retention (days)"|t('craft-cmp'),
        instructions: "Delete consent records older than this. 0 = keep forever."|t('craft-cmp'),
        id: 'consentRetentionDays', name: 'settings[consentRetentionDays]', value: settings.consentRetentionDays, type: 'number', size: 6,
    }) }}
    {{ forms.lightswitchField({
        label: "Hash stored IP addresses"|t('craft-cmp'),
        instructions: "Recommended. Stores a SHA-256 hash instead of the raw IP."|t('craft-cmp'),
        id: 'hashIp', name: 'settings[hashIp]', on: settings.hashIp,
    }) }}

    <hr>
    <h2>{{ "Headless API security"|t('craft-cmp') }}</h2>

    {{ forms.editableTableField({
        label: "Allowed origins (CORS)"|t('craft-cmp'),
        instructions: "Origins permitted to call the headless API from the browser, e.g. https://www.example.com. Leave empty for same-origin / server-to-server only."|t('craft-cmp'),
        id: 'allowedOrigins',
        name: 'settings[allowedOrigins]',
        cols: { origin: { heading: "Origin"|t('craft-cmp'), type: 'singleline', placeholder: 'https://www.example.com' } },
        rows: settings.allowedOrigins,
        addRowLabel: "Add an origin"|t('craft-cmp'),
        allowAdd: true,
        allowDelete: true,
        allowReorder: true,
        static: false,
    }) }}
    {{ forms.autosuggestField({
        label: "Shared secret"|t('craft-cmp'),
        instructions: "Optional. When set, POST /cookie-consent/save must send it as the `X-Consent-Secret` header. Supports environment variables."|t('craft-cmp'),
        id: 'sharedSecret', name: 'settings[sharedSecret]', value: settings.sharedSecret, suggestEnvVars: true,
    }) }}
{% endblock %}
